#!/usr/bin/env bash
# CodeMaster vs Claude Code benchmark — single command entry point.
#
# Usage:
#   ./benchmark/run              # full run (5 prompts)
#   ./benchmark/run --quick      # first prompt only (smoke test)
#   ./benchmark/run --no-judge   # skip LLM quality scoring
#   ./benchmark/run --help       # all options
#
# Requirements:
#   - claude CLI on PATH (npm install -g @anthropic-ai/claude-code)
#   - Python 3.10+
#   - codemaster installed (install.sh) OR run from repo root

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Verify claude CLI is available
if ! command -v claude &>/dev/null; then
  echo "Error: 'claude' not found on PATH."
  echo "Install: npm install -g @anthropic-ai/claude-code"
  exit 1
fi

echo "CodeMaster vs Claude Code Benchmark"
echo "──────────────────────────────────────────────────────"

exec python3 "$SCRIPT_DIR/benchmark.py" "$@"
