#!/usr/bin/env node
import { spawnSync } from 'child_process';
import { fileURLToPath } from 'url';
import path from 'path';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

const tsx = path.join(__dirname, '..', 'node_modules', '.bin', 'tsx');
const target = path.join(__dirname, '..', 'src', 'index.tsx');

while (true) {
  const result = spawnSync(tsx, [target, ...process.argv.slice(2)], {
    stdio: 'inherit',
    env: process.env,
    // No cwd — inherits user's shell cwd
  });
  if (result.status === 42) {
    spawnSync('claude', [], { stdio: 'inherit', env: process.env });
    continue;
  }
  process.exit(result.status ?? 0);
}
